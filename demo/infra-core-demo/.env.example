# ELK 스택 기본 인증
ELASTIC_PASSWORD=changeme
KIBANA_PASSWORD=changeme

# BFF 서비스
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Redis (BFF Fallback 캐시)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 업스트림 서비스 URL (로컬 개발)
USER_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083

# CORS 허용 오리진
ALLOWED_ORIGINS=http://localhost:3001

# Kafka (로컬 Docker)
KAFKA_BROKERS=localhost:29092
KAFKA_CONSUMER_GROUP=infra-core-workers
KAFKA_TOPIC=app-events
KAFKA_DLQ_TOPIC=app-events-dlq
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_DELAY_MS=1000

# Kafka SASL (MSK 운영 환경)
# KAFKA_SASL_MECHANISM=scram-sha-512
# KAFKA_SASL_USERNAME=kafka-admin
# KAFKA_SASL_PASSWORD=REPLACE_WITH_SECRETS_MANAGER_VALUE

# AWS (운영 환경 — EC2 IAM Role 사용 권장, 직접 입력 금지)
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
