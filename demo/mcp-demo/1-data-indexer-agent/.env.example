# ==========================================
# Data Indexer Agent Environment Variables
# ==========================================

# [Neo4j Graph Database]
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mcp-demo-password

# [SQLite BM25 FTS5 Database]
SQLITE_DB_PATH=./data/bm25_index.db

# [Plugin Configuration]
# 도메인 충돌 방지를 위한 전역 네임스페이스 접두사
GLOBAL_NAMESPACE_PREFIX=ORG

# [Jira Plugin]
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
JIRA_EMAIL=dev@your-company.com

# [GitHub Plugin]
GITHUB_API_TOKEN=your_github_pat_token
GITHUB_ORG_NAME=your-company-org
