# ==========================================
# MCP Serving Agent Environment Variables
# ==========================================

# [Log Settings]
RUST_LOG=info
# 디버그 모드 시 debug로 변경

# [Database Connection]
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mcp-demo-password

# [MCP Server Settings]
# 통신 모드: stdio 또는 sse
MCP_TRANSPORT_MODE=stdio
# SSE 모드일 경우 바인딩할 포트
MCP_SSE_PORT=3020

# [Guardrail Settings]
# 마스킹할 민감 정보 정규식 리스트 (쉼표로 구분)
REDACT_PATTERNS="(?i)password,secret,token,api_key"
